{
  "App": {
    "PublicUrl": "https://your-domain.example"
  },
  "ConnectionStrings": {
    "DefaultConnection": "Data Source=/absolute/path/to/chat.db"
  },
  "FileUpload": {
    "Path": "/absolute/path/to/uploads"
  },
  "Google": {
    "ClientId": "your-google-client-id",
    "ClientSecret": "your-google-client-secret"
  },
  "Providers": {
    "OpenRouter": {
      "ApiKey": "your-openrouter-api-key"
    },
    "Groq": {
      "ApiKey": "your-groq-api-key"
    },
    "AiStudio": {
      "ApiKey": "your-aistudio-api-key"
    },
    "Chutes": {
      "ApiKey": "your-chutes-api-key"
    },
    "Mistral": {
      "ApiKey": "your-mistral-api-key"
    },
    "FreeTier": {
      "ApiKey": "your-free-tier-api-key"
    }
  }
}
