@page "/"
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager NavigationManager
@inject IJSRuntime Js

<CascadingAuthenticationState>
    <AuthorizeView>
        <Authorized>
            @if (isInitialized)
            {
                <MudContainer>
                    <MudText>Redirecting to chat...</MudText>
                </MudContainer>
                <script>
                    setTimeout(() => {
                        window.location.href = '/Chat';
                    }, 100);
                </script>
            }
        </Authorized>
        <NotAuthorized>
            <MudContainer MaxWidth="MaxWidth.ExtraSmall" Class="d-flex flex-column align-center justify-center mud-height-full">
                <MudPaper Class="pa-8 rounded-lg text-center" Elevation="3">
                    <img src="m1chat-small.png" alt="M1 Chat" style="max-width: 150px; margin-bottom: 24px;" />
                    <MudText Typo="Typo.h5" Class="mb-4">Welcome to M1 Chat</MudText>
                    <MudText Typo="Typo.body2" Class="mb-6">Please sign in to continue.</MudText>
                    <MudButton OnClick="SignInWithGoogle"
                               Variant="Variant.Filled"
                               Color="Color.Primary"
                               Size="Size.Large"
                               StartIcon="@Icons.Custom.Brands.Google"
                               Class="rounded-xl">
                        Sign in with Google
                    </MudButton>
                </MudPaper>
            </MudContainer>
        </NotAuthorized>
    </AuthorizeView>
</CascadingAuthenticationState>

@code {
    private bool isInitialized = false;

    protected override void OnInitialized()
    {
        isInitialized = true;
        if (OperatingSystem.IsBrowser())
        {
            Js.InvokeVoidAsync("window.hideBlazorLoadingScreen");
        }
    }

    private void SignInWithGoogle()
    {
        NavigationManager.NavigateTo("/auth/google-login?returnUrl=/Chat", forceLoad: true);
    }
}