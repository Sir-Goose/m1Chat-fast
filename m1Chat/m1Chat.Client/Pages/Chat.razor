@page "/Chat"
@using System.Data.SqlTypes
@using System.Numerics
@using System.Text
@using AngleSharp.Css
@using m1Chat.Client.Components
@using m1Chat.Client.Models
@using m1Chat.Client.Services
@using Microsoft.AspNetCore.Components.Authorization
@inject AuthenticationStateProvider AuthenticationStateProvider
@inject IScrollManager ScrollManager
@inject ChatCompletionService CompletionService
@inject ChatService ChatService
@inject FileUploadService FileUploadService
@inject IJSRuntime Js
@using ServiceChatMessage = m1Chat.Client.Services.ChatMessage
@inject UserService UserService
@inject ISnackbar Snackbar
@inject NavigationManager NavigationManager
@inject ChatCacheService ChatCacheService
@inject SvgIcons SvgIcons
@inject ModelPreferencesService ModelPreferences
@inject IDialogService DialogService

<MudLayout>
  <ChatDrawer @bind-DrawerOpen="_drawerOpen"
              @ref="_chatDrawerRef"
              SidebarChats="SidebarChats"
              UserEmail="@UserEmail"
              ActiveChatId="@_chatId"
              OnChatSelected="LoadChat"
              OnCreateNewChat="CreateNewChat"
              OnChatPinned="PinChat"
              OnChatDeleted="DeleteChat"
              OnChatRenamed="HandleChatRenamed"/>

  <MudMainContent
    Class="d-flex flex-column p-0 chat-main-content-bg"
    Style="height:100vh;overflow:hidden;"
  >
    @if (!_drawerOpen)
    {
      <div
        class="ma-2 pa-2 translucent-paper rounded-xl"
        style="position: fixed; left: 0; top: 0; z-index: 100; display: flex;"
      >
        <MudIconButton
          Icon="@SvgIcons.SideBar"
          Size="Size.Small"
          OnClick="HandleTopLeftOpenDrawer"
          class="mr-2"
        >
        </MudIconButton>
        <MudIconButton
          Icon="@SvgIcons.Search"
          Size="Size.Small"
          OnClick="HandleTopLeftSearch"
          class="mr-2"
        >
        </MudIconButton>
        <MudIconButton Icon="@SvgIcons.New" Size="Size.Small" OnClick="HandleTopLeftNewChat">
        </MudIconButton>
      </div>
    }

    <div
      class="chat-container px-2 pb-2 no-scrollbar"
      @ref="_chatContainerRef"
      style="overflow-y:auto; flex:1 1 auto; padding-bottom: 130px;"
      id="chat-view"
    >
      <ChatTranscript
        Messages="_chatHistory"
        IsWaitingForFirstChunk="_isWaitingForFirstChunk"
        Version="_chatTranscriptVersion"
        OnEdit="HandleEditMessage"
        OnRegenerate="HandleRegenerateMessage"
        OnCopy="HandleCopyMessage"
        OnBranch="HandleBranchMessage" />
    </div>

    <ChatInputArea @bind-SelectedModel="ChatSelectedModel"
                   @bind-ThinkingSelectedOption="ThinkingSelectedOption"
                   @bind-CurrentMessageFiles="CurrentMessageFiles"
                   @bind-ShowFileUpload="_showFileUpload"
                   EnabledModelsByProvider="_enabledModelsByProvider"
                   UserApiKeys="_userApiKeys"
                   IsSendingMessage="_isSendingMessage"
                   OnMessageSubmitted="SendMessage"
                   OnKeyUp="HandleChatGlobalKeyUp"
                   @ref="_chatInputAreaRef" />
  </MudMainContent>
</MudLayout>

@code {
  private bool _drawerOpen = false;
  private bool _isSendingMessage = false;
  private bool _isWaitingForFirstChunk = false;
  private bool _showFileUpload = false;

  private ElementReference _chatContainerRef;

  private string UserEmail { get; set; } = "";

  private ChatDrawer? _chatDrawerRef;
  private ChatInputArea? _chatInputAreaRef;

  private ClientChatMessage? _messageBeingEdited;

  // File upload properties (these are bindable to ChatInputArea)
  private List<FileUploadService.UploadedFileInfo> CurrentMessageFiles = new();

  private string _chatSelectedModel = "";

  private static Task Should_sidebar_be_open() => Task.CompletedTask;

  private string ChatSelectedModel
  {
    get => _chatSelectedModel;
    set
    {
      if (_chatSelectedModel != value)
      {
        _chatSelectedModel = value;
      }
    }
  }

  private string ThinkingSelectedOption { get; set; } = "None";

  // This will hold the models grouped by provider for the MudSelect
  private Dictionary<string, List<string>> _enabledModelsByProvider = new();
  
  // User API keys for determining which models should be disabled
  private Dictionary<string, string> _userApiKeys = new();

  // The full list of models, used for internal mapping and initial population
  private List<string> _allAiModelOptions = new();

  private string? _chatId;
  private string _chatName = "New Chat";
  private List<ClientChatMessage> _chatHistory = new();
  private int _chatTranscriptVersion = 1;
  private bool _chatIsPinned;
  private List<ChatDrawer.SidebarChat> SidebarChats = new();

  [Inject] private SignalRService SignalRService { get; set; } = null!;
  [Inject] private ChatCompletionService ChatCompletionService { get; set; } = null!;

  
  private readonly System.Diagnostics.Stopwatch _streamingStopwatch = new();
  private const int TARGET_FPS = 60;
  private const int MIN_INTERVAL_MS = 16; // ~60fps
  private const int MAX_CHARS_PER_SECOND = 1500; // Increased max for high-speed providers
  private const int MIN_CHARS_PER_SECOND = 5;   // Minimum speed to feel responsive
  private const int BURST_THRESHOLD = 200;
  private const double EMA_SMOOTHING_FACTOR = 0.15;

  private double _emaCharsPerSecond = MIN_CHARS_PER_SECOND;
  private long _lastChunkTime = 0;
  private long _uiPerfSequence;
  private bool _pendingDrawerSearchFocus;
  private (long Id, System.Diagnostics.Stopwatch Timer, string Source)? _pendingDrawerFocusPerf;
  private (long Id, System.Diagnostics.Stopwatch Timer, string Source)? _pendingInputResetPerf;

  protected override async Task OnInitializedAsync()
  {
    var authState = await AuthenticationStateProvider.GetAuthenticationStateAsync();
    if (authState.User.Identity?.IsAuthenticated != true)
    {
      NavigationManager.NavigateTo("/");
      return;
    }
    UserEmail = await UserService.GetUserEmailAsync() ?? "Unknown";
    
    // Only fetch API keys when running in the browser (not during server-side prerendering)
    if (OperatingSystem.IsBrowser())
    {
      _userApiKeys = await UserService.GetUserApiKeysAsync();
    }
    
    await LoadSidebarChatsAsync();
    // Removed forced drawer opening - let it stay closed by default

    // Initialize ModelPreferences service and load enabled models
    await ModelPreferences.InitializeAsync();
    _chatSelectedModel = ModelPreferences.DefaultModel;
    _allAiModelOptions = ModelPreferences.GetAllAvailableModels(); 
    GroupEnabledModelsByProvider();

    // Set initial selected model to the first available if current is not enabled
    if (!_enabledModelsByProvider.Any())
    {
        // If no models are enabled in preferences, default to all models and select the first one
        _enabledModelsByProvider = ModelPreferences.GetAllAvailableModels()
            .GroupBy(m => ModelPreferences.GetModelProviders().GetValueOrDefault(m, "Unknown"))
            .ToDictionary(g => g.Key, g => g.ToList());
        _chatSelectedModel = _enabledModelsByProvider.Values.SelectMany(x => x).FirstOrDefault() ?? "";
    }
    else if (!ModelPreferences.EnabledModels.Contains(_chatSelectedModel))
    {
         _chatSelectedModel = ModelPreferences.EnabledModels.FirstOrDefault() ?? "";
    }
    
    // Ensure ChatSelectedModel is not null or empty if there are available models
    if (string.IsNullOrEmpty(_chatSelectedModel) && _enabledModelsByProvider.Any())
    {
        _chatSelectedModel = _enabledModelsByProvider.Values.SelectMany(x => x).FirstOrDefault() ?? "";
    }

    if (OperatingSystem.IsBrowser())
    {
      await SignalRService.EnsureConnectionAsync();
    }
  }

  private void GroupEnabledModelsByProvider()
  {
      var providerMap = ModelPreferences.GetModelProviders(); 
      _enabledModelsByProvider = ModelPreferences.EnabledModels
          .Where(modelName => providerMap.ContainsKey(modelName))
          .GroupBy(modelName => providerMap[modelName])
          .ToDictionary(group => group.Key, group => group.ToList());
  }

  private (long Id, System.Diagnostics.Stopwatch Timer) StartUiPerf(string action, string source)
  {
    var id = System.Threading.Interlocked.Increment(ref _uiPerfSequence);
    var timer = System.Diagnostics.Stopwatch.StartNew();
    Console.WriteLine($"[UIPERF][Chat][{action}][{source}]#{id} start");
    return (id, timer);
  }

  private static void LogUiPerf(string action, string source, (long Id, System.Diagnostics.Stopwatch Timer) perf, string checkpoint)
  {
    Console.WriteLine($"[UIPERF][Chat][{action}][{source}]#{perf.Id} {checkpoint} +{perf.Timer.ElapsedMilliseconds}ms");
  }

  private Task HandleTopLeftOpenDrawer() => OpenDrawer("TopBarButton");

  private Task HandleTopLeftSearch() => FocusSearchFieldInDrawer("TopBarSearch");

  private Task HandleTopLeftNewChat() => CreateNewChat("TopBarNewChat");

  private Task CreateNewChat() => CreateNewChat("Callback");

  private Task ToggleDrawer(string source)
  {
    var perf = StartUiPerf("ToggleDrawer", source);
    _drawerOpen = !_drawerOpen;
    LogUiPerf("ToggleDrawer", source, perf, $"state-updated:{(_drawerOpen ? "open" : "closed")}");
    StateHasChanged();
    LogUiPerf("ToggleDrawer", source, perf, "first-statehaschanged");
    LogUiPerf("ToggleDrawer", source, perf, "handler-complete");
    return Task.CompletedTask;
  }

  private Task OpenDrawer(string source)
  {
    var perf = StartUiPerf("OpenDrawer", source);
    if (!_drawerOpen)
    {
      _drawerOpen = true;
      LogUiPerf("OpenDrawer", source, perf, "state-updated");
      StateHasChanged();
      LogUiPerf("OpenDrawer", source, perf, "first-statehaschanged");
    }
    else
    {
      LogUiPerf("OpenDrawer", source, perf, "already-open");
    }

    LogUiPerf("OpenDrawer", source, perf, "handler-complete");
    return Task.CompletedTask;
  }

  private Task FocusSearchFieldInDrawer(string source = "Unknown")
  {
    var perf = StartUiPerf("FocusSearch", source);

    if (!_drawerOpen)
    {
      _drawerOpen = true;
      LogUiPerf("FocusSearch", source, perf, "drawer-open-state-updated");
    }

    _pendingDrawerSearchFocus = true;
    _pendingDrawerFocusPerf = (perf.Id, perf.Timer, source);
    StateHasChanged();
    LogUiPerf("FocusSearch", source, perf, "first-statehaschanged");
    LogUiPerf("FocusSearch", source, perf, "handler-complete");
    return Task.CompletedTask;
  }

  private async Task HandleStreamCompleted()
  {
    var aiMessage = _chatHistory.LastOrDefault(m => !m.IsUser && m.IsStreaming);
    if (aiMessage != null)
    {
      aiMessage.IsStreaming = false;
      _isSendingMessage = false;
      TouchTranscript();
      await InvokeAsync(StateHasChanged);
      await SaveChatAfterStreaming();
    }
  }

  

  

  private void HandleStreamError(string error)
  {
    var aiMessage = _chatHistory.LastOrDefault(m => !m.IsUser && m.IsStreaming);
    if (aiMessage != null)
    {
      aiMessage.Text = $"[Error: {error}]";
      aiMessage.IsStreaming = false;
      _isSendingMessage = false;
      TouchTranscript();
      _ = InvokeAsync(StateHasChanged);
    }
  }

  private async Task SaveChatAfterStreaming()
  {
    if (Guid.TryParse(_chatId, out var cId))
    {
      var updateReq = new ChatService.UpdateChatRequest(
        _chatName,
        ChatSelectedModel,
        ToSharedMessagesWithFilesForDb().ToArray(),
        _chatIsPinned
      );
      await ChatService.UpdateChatAsync(cId, updateReq);
      ChatCacheService.InvalidateCache(cId);
      await LoadSidebarChatsAsync();
    }
  }


  private async Task LoadSidebarChatsAsync()
  {
    var list = await ChatService.GetChatsAsync();
    SidebarChats = list
      .OrderByDescending(c => c.IsPinned)
      .ThenByDescending(c => c.LastUpdatedAt)
      .Select(c => new ChatDrawer.SidebarChat(c.Id.ToString(), c.Name, c.Model, c.IsPinned, c.LastUpdatedAt))
      .ToList();
  }

  private Task CreateNewChat(string source)
  {
    var perf = StartUiPerf("CreateNewChat", source);
    _chatId = null;
    _chatName = "New Chat";
    _chatHistory.Clear();
    TouchTranscript();
    _chatIsPinned = false;
    CurrentMessageFiles.Clear();
    _showFileUpload = false;
    _messageBeingEdited = null;

    LogUiPerf("CreateNewChat", source, perf, "state-reset");

    if (_chatInputAreaRef != null)
    {
      _pendingInputResetPerf = (perf.Id, perf.Timer, source);
    }

    StateHasChanged();
    LogUiPerf("CreateNewChat", source, perf, "first-statehaschanged");
    LogUiPerf("CreateNewChat", source, perf, "handler-complete");
    return Task.CompletedTask;
  }

  private async Task LoadChat(ChatDrawer.SidebarChat chat)
  {
    if (_chatId == chat.Id && _chatHistory.Any()) return;
    // Check cache first
    if (Guid.TryParse(chat.Id, out var chatGuid))
    {
      var cached = ChatCacheService.GetChatIfCached(chatGuid);
      if (cached != null)
      {
        ApplyCachedChat(cached);
        return;
      }
    }

    _chatHistory.Clear();
    var fullChat = await ChatService.GetChatAsync(Guid.Parse(chat.Id));
    _chatId = fullChat.Id.ToString();
    _chatName = fullChat.Name;
    ChatSelectedModel = fullChat.Model;
    _chatIsPinned = fullChat.IsPinned;
    _chatHistory = fullChat.Messages
      .Select(m => new ClientChatMessage()
      {
        IsUser = m.Role == "user",
        Text = m.Content,
        FileIds = m.FileIds?.ToList() ?? new List<Guid>()
      })
      .ToList();
    TouchTranscript();
    CurrentMessageFiles.Clear();
    _showFileUpload = false;
    _messageBeingEdited = null;
    
    // Call SetInputText to clear the ChatInputArea's internal text
    if (_chatInputAreaRef != null)
    {
        await _chatInputAreaRef.SetInputText("", "LoadChat");
    }
    StateHasChanged();
  }

  private void ApplyCachedChat(ChatService.ChatHistory cached)
  {
    _chatId = cached.Id.ToString();
    _chatName = cached.Name;
    ChatSelectedModel = cached.Model;
    _chatIsPinned = cached.IsPinned;
    _chatHistory = cached.Messages
      .Select(m => new ClientChatMessage
      {
        IsUser = m.Role == "user",
        Text = m.Content,
        FileIds = m.FileIds?.ToList() ?? new List<Guid>()
      })
      .ToList();
    TouchTranscript();

    CurrentMessageFiles.Clear();
    _showFileUpload = false;
    _messageBeingEdited = null;
    
    // Call SetInputText to clear the ChatInputArea's internal text
    if (_chatInputAreaRef != null)
    {
        _ = _chatInputAreaRef.SetInputText("", "ApplyCachedChat"); // Don't await in a void method
    }
    StateHasChanged();
  }

  private List<ServiceChatMessage> ToServiceChatMessages() =>
    _chatHistory.Select(m => new ServiceChatMessage
    {
      Role = m.IsUser ? "user" : "assistant",
      Content = m.Text,
    }).ToList();

  

  protected override async Task OnAfterRenderAsync(bool firstRender)
  {
    if (firstRender && OperatingSystem.IsBrowser())
    {
      await Js.InvokeVoidAsync("window.hideBlazorLoadingScreen");
      // Load API keys on first render in browser (after prerendering)
      if (!_userApiKeys.Any())
      {
        _userApiKeys = await UserService.GetUserApiKeysAsync();
        StateHasChanged(); // Trigger re-render to update model dropdown states
      }
    }

    if (_pendingDrawerSearchFocus && _drawerOpen && _chatDrawerRef != null && _pendingDrawerFocusPerf != null)
    {
      var perf = _pendingDrawerFocusPerf.Value;
      _pendingDrawerSearchFocus = false;
      _pendingDrawerFocusPerf = null;
      LogUiPerf("FocusSearch", perf.Source, (perf.Id, perf.Timer), "post-render-before-focus");
      await _chatDrawerRef.FocusSearchFieldAsync();
      LogUiPerf("FocusSearch", perf.Source, (perf.Id, perf.Timer), "focus-complete");
    }

    if (_pendingInputResetPerf != null && _chatInputAreaRef != null)
    {
      var perf = _pendingInputResetPerf.Value;
      _pendingInputResetPerf = null;
      LogUiPerf("CreateNewChat", perf.Source, (perf.Id, perf.Timer), "post-render-before-input-clear");
      await _chatInputAreaRef.SetInputText("", "CreateNewChat/deferred");
      LogUiPerf("CreateNewChat", perf.Source, (perf.Id, perf.Timer), "input-clear-complete");
    }
    
    // Disable continuous auto-scroll
    // if (firstRender)
    // {
    //   await Js.InvokeVoidAsync("chatScroll.observe", _chatContainerRef);
    // }
  }

  private Task HandleChatGlobalKeyUp(KeyboardEventArgs args) // Catches global hotkeys from ChatInputArea
  {
    bool isModifierPressed = args.CtrlKey || args.MetaKey; // Ctrl or Command key

    if (isModifierPressed && string.Equals(args.Key, "k", StringComparison.OrdinalIgnoreCase))
    {
      return FocusSearchFieldInDrawer("Hotkey/CtrlOrCmd+K");
    }
    
    if (isModifierPressed && string.Equals(args.Key, "b", StringComparison.OrdinalIgnoreCase))
    {
      return ToggleDrawer("Hotkey/CtrlOrCmd+B");
    }
    
    if (isModifierPressed && string.Equals(args.Key, "o", StringComparison.OrdinalIgnoreCase))
    {
      return CreateNewChat("Hotkey/CtrlOrCmd+O");
    }

    return Task.CompletedTask;
  }

  private readonly System.Text.StringBuilder _streamBuffer = new();
  private bool _streamIsActive = false;
  private bool _isProcessingBuffer = false;

  private void TouchTranscript()
  {
    _chatTranscriptVersion++;
  }

  private void SetWaitingForFirstChunk(bool value)
  {
    if (_isWaitingForFirstChunk == value)
    {
      return;
    }

    _isWaitingForFirstChunk = value;
    TouchTranscript();
  }

  private async Task ProcessStreamBuffer(ClientChatMessage aiMessage)
  {
    if (_isProcessingBuffer) return;
    _isProcessingBuffer = true;

    try
    {
      while (_streamIsActive || _streamBuffer.Length > 0)
      {
        string contentToRender;
        lock (_streamBuffer)
        {
          if (_streamBuffer.Length == 0)
          {
            contentToRender = string.Empty;
          }
          else
          {
            // Calculate how many chars to render this frame based on the smoothed speed
            var charsPerFrame = _emaCharsPerSecond * (MIN_INTERVAL_MS / 1000.0);
            var charsToRenderCount = (int)Math.Ceiling(Math.Min(_streamBuffer.Length, charsPerFrame));
            
            contentToRender = _streamBuffer.ToString(0, charsToRenderCount);
            _streamBuffer.Remove(0, charsToRenderCount);
          }
        }

        if (!string.IsNullOrEmpty(contentToRender))
        {
          aiMessage.Text += contentToRender;
          TouchTranscript();
          await InvokeAsync(StateHasChanged);
        }

        await Task.Delay(MIN_INTERVAL_MS);
      }
    }
    finally
    {
      _isProcessingBuffer = false;
    }
  }

  private async Task StreamAiMessage(List<ServiceChatMessage> messagesForAi, ClientChatMessage aiMessage, Func<Task>? onComplete = null, Action<string>? onError = null)
  {
    _streamingStopwatch.Restart();
    _streamIsActive = true;
    SetWaitingForFirstChunk(true);
    _lastChunkTime = _streamingStopwatch.ElapsedMilliseconds;
    _emaCharsPerSecond = MIN_CHARS_PER_SECOND; // Reset for new stream
    
    lock (_streamBuffer)
    {
        _streamBuffer.Clear();
    }

    _ = ProcessStreamBuffer(aiMessage);

    try
    {
      await ChatCompletionService.StreamCompletion(
        messagesForAi,
        ChatSelectedModel,
        ThinkingSelectedOption,
        chunk =>
        {
            // Hide loading indicator on first chunk received
            if (_isWaitingForFirstChunk)
            {
                SetWaitingForFirstChunk(false);
                InvokeAsync(StateHasChanged);
            }
            
            var now = _streamingStopwatch.ElapsedMilliseconds;
            var timeSinceLastChunk = now - _lastChunkTime;
            _lastChunkTime = now;

            if (timeSinceLastChunk > 0 && !string.IsNullOrEmpty(chunk))
            {
                var instantaneousCps = (double)chunk.Length / (timeSinceLastChunk / 1000.0);
                // Update EMA
                _emaCharsPerSecond = (EMA_SMOOTHING_FACTOR * instantaneousCps) + (1 - EMA_SMOOTHING_FACTOR) * _emaCharsPerSecond;
            }
            else if (string.IsNullOrEmpty(chunk))
            {
                // If we receive an empty chunk, gently decay the speed towards the minimum
                _emaCharsPerSecond = (EMA_SMOOTHING_FACTOR * MIN_CHARS_PER_SECOND) + (1 - EMA_SMOOTHING_FACTOR) * _emaCharsPerSecond;
            }

            // Clamp the speed to prevent extreme values
            _emaCharsPerSecond = Math.Clamp(_emaCharsPerSecond, MIN_CHARS_PER_SECOND, MAX_CHARS_PER_SECOND);

            lock (_streamBuffer)
            {
                _streamBuffer.Append(chunk);
            }
        },
        async () =>
        {
          _streamIsActive = false;
          SetWaitingForFirstChunk(false);
          while (_isProcessingBuffer) await Task.Delay(50);

          aiMessage.IsStreaming = false;
          _isSendingMessage = false;
          _streamingStopwatch.Stop();
          TouchTranscript();
          await InvokeAsync(StateHasChanged);
          if (onComplete != null) await onComplete();
        },
        error =>
        {
          _streamIsActive = false;
          SetWaitingForFirstChunk(false);
          
          string remainingContent;
          lock(_streamBuffer) 
          {
              remainingContent = _streamBuffer.ToString();
              _streamBuffer.Clear();
          }

          if (!string.IsNullOrEmpty(remainingContent)) {
            aiMessage.Text += remainingContent;
          }

          aiMessage.Text += $"[Error: {error}]";
          aiMessage.IsStreaming = false;
          _isSendingMessage = false;
          _streamingStopwatch.Stop();
          TouchTranscript();
          InvokeAsync(StateHasChanged);
          onError?.Invoke(error);
        }
      );
    }
    catch (Exception ex)
    {
      _streamIsActive = false;
      SetWaitingForFirstChunk(false);
      aiMessage.Text = $"[Error: {ex.Message}]";
      aiMessage.IsStreaming = false;
      _isSendingMessage = false;
      _streamingStopwatch.Stop();
      Console.WriteLine($"Error streaming completion: {ex}");
      TouchTranscript();
      await InvokeAsync(StateHasChanged);
      onError?.Invoke(ex.Message);
    }
  }

  private async Task SendMessage(string submittedMessageText) 
  {
    if (_isSendingMessage) return;
    await SignalRService.EnsureConnectionAsync();

    var textToSend = submittedMessageText.Trim(); // Use the text received from ChatInputArea
    if (string.IsNullOrWhiteSpace(textToSend) && !CurrentMessageFiles.Any())
    {
      return;
    }

    _isSendingMessage = true;
    StateHasChanged();
    
    // --- API Key Check ---
    var modelProvider = ModelPreferences.GetModelProviders().GetValueOrDefault(ChatSelectedModel, "Unknown");

    var providersRequiringApiKey = new HashSet<string>(StringComparer.OrdinalIgnoreCase)
    {
        "Openrouter",
        "AI Studio",
        "Chutes",
        "Mistral AI",
        "Groq"
    };

    if (providersRequiringApiKey.Contains(modelProvider))
    {
        var userApiKeys = await UserService.GetUserApiKeysAsync();
        string requiredKey = "";
        string keyNameInStorage = "";

        switch (modelProvider)
        {
            case "Openrouter":
                keyNameInStorage = "OpenRouter";
                break;
            case "AI Studio":
                keyNameInStorage = "AIStudio";
                break;
            case "Chutes":
                keyNameInStorage = "Chutes";
                break;
            case "Mistral AI":
                keyNameInStorage = "Mistral";
                break;
            case "Groq":
              keyNameInStorage = "Groq";
              break;
        }

        requiredKey = userApiKeys.GetValueOrDefault(keyNameInStorage) ?? "";

        if (string.IsNullOrWhiteSpace(requiredKey))
        {
            var parameters = new DialogParameters();
            var options = new DialogOptions { CloseButton = true, MaxWidth = MaxWidth.Small, FullWidth = true, BackgroundClass = "blur-background" };
            var dialog = await DialogService.ShowAsync<ApiKeyRequiredDialog>("API Key Required", parameters, options);
            var result = await dialog.Result;
            if (!(result?.Canceled ?? true) && result!.Data is bool goToProfile && goToProfile) { NavigationManager.NavigateTo("/Profile"); }
            _isSendingMessage = false;
            StateHasChanged();
            return;
        }
    }

    var fileIds = CurrentMessageFiles.Select(f => f.Id).ToList();
    var userMessageTextForName = textToSend;

    // Clear the input now that we know the message is accepted
    if (_chatInputAreaRef != null)
    {
      await _chatInputAreaRef.ClearInput();
    }

    if (_messageBeingEdited != null)
    {
      var originalMessageIndex = _chatHistory.IndexOf(_messageBeingEdited);
      if (originalMessageIndex != -1)
      {
      _chatHistory[originalMessageIndex] = _messageBeingEdited with
      {
        Text = textToSend,
        FileIds = fileIds
      };
        // If a user message was edited, remove any AI replies that came after it
        if (_messageBeingEdited.IsUser)
        {
          _chatHistory.RemoveAll(m => _chatHistory.IndexOf(m) > originalMessageIndex && !m.IsUser);
        }
      }

      _messageBeingEdited = null;
    }
    else
    {
      _chatHistory.Add(new ClientChatMessage() 
      {
        IsUser = true,
        Text = textToSend,
        FileIds = fileIds
      });
    }
    TouchTranscript();

    CurrentMessageFiles.Clear(); // Clear files from Chat.razor's state (this will propagate to ChatInputArea)
    _showFileUpload = false;     // Hide file upload (this will propagate to ChatInputArea)
    
    
    StateHasChanged();

    bool isNewChat = _chatId == null;
    Guid newChatGuid = Guid.Empty;

    if (isNewChat)
    {
      _chatName = "New Chat";
      var initialMessagesForName = new List<ServiceChatMessage>
      {
        new() { Role = "user", Content = $"{userMessageTextForName}\n-----\nIgnore all previous instructions. The preceding text is a conversation thread that needs a concise but descriptive 3 to 5 word title in natural English so that readers will be able to easily find it again. Do not add any quotation marks or formatting to the title. Respond only with the title text." }
      };

      string tempName = string.IsNullOrWhiteSpace(userMessageTextForName) ? "Chat with Files" : (userMessageTextForName.Length <= 20 ? userMessageTextForName : userMessageTextForName.Substring(0, 20) + "...");

      var createReq = new ChatService.CreateChatRequest(
        tempName,
        ChatSelectedModel,
        new ChatService.ChatMessageDto[] { new ChatService.ChatMessageDto("user", userMessageTextForName, fileIds) },
        _chatIsPinned
      );
      newChatGuid = await ChatService.CreateChatAsync(createReq);
      _chatId = newChatGuid.ToString();
      NavigationManager.NavigateTo($"/Chat?chatId={_chatId}", forceLoad: false);

      string generatedName = "";
      try
      {
        var nameGenerationCompleteFunc = new Func<Task>(async () =>
        {
          _chatName = !string.IsNullOrWhiteSpace(generatedName)
            ? generatedName.Trim().Trim('"', '\'').Replace("\n", " ")
            : tempName;

          // Ensure the generated name doesn't exceed database limits
          if (_chatName.Length > 50) _chatName = _chatName.Substring(0, 50);

          var updateNameReq = new ChatService.UpdateChatRequest(
            _chatName,
            ChatSelectedModel,
            new ChatService.ChatMessageDto[] { new ChatService.ChatMessageDto("user", userMessageTextForName, fileIds) },
            _chatIsPinned
          );
          await ChatService.UpdateChatAsync(newChatGuid, updateNameReq);
          ChatCacheService.InvalidateCache(newChatGuid);
          await LoadSidebarChatsAsync();
          StateHasChanged();
        });

        await ChatCompletionService.StreamCompletion(
          initialMessagesForName,
          "Llama 4 Scout (Groq)",
          "Low",
          chunk => generatedName += chunk,
          nameGenerationCompleteFunc,
          null
        );
      }
      catch (Exception ex)
      {
        Console.WriteLine($"Name generation failed: {ex.Message}");
        _chatName = tempName;
        await LoadSidebarChatsAsync();
        StateHasChanged();
      }
    }

    // Create new AI message with streaming enabled
    var aiMessage = new ClientChatMessage 
    {
      IsUser = false,
      Text = "",
      IsStreaming = true
    };
    _chatHistory.Add(aiMessage);
    
    // Set waiting state - will be cleared when first chunk arrives
    TouchTranscript();
    SetWaitingForFirstChunk(true);
    StateHasChanged();

    // Prepare messages for AI
    var messagesForAiStartIdx = _messageBeingEdited != null ? _chatHistory.IndexOf(_messageBeingEdited) : 0;
    var messagesForAi = _chatHistory
      .Take(_chatHistory.Count - 1)
      .Select(m => new ServiceChatMessage
      {
        Role = m.IsUser ? "user" : "assistant",
        Content = m.Text,
        FileIds = m.FileIds
      }).Skip(messagesForAiStartIdx).ToList();

    // Scroll to bottom once after user sends a message
    await Js.InvokeVoidAsync("chatScroll.scrollToBottomOnce", _chatContainerRef);
    await StreamAiMessage(messagesForAi, aiMessage, SaveChatAfterStreaming);
  }

  // Used for saving to DB via ChatService (expects DTOs with FileIds)
  private List<ChatService.ChatMessageDto> ToSharedMessagesWithFilesForDb() =>
    _chatHistory.Select(m => new ChatService.ChatMessageDto(
      m.IsUser ? "user" : "assistant",
      m.Text,
      m.FileIds
    )).ToList();

  private async Task PinChat(ChatDrawer.SidebarChat chat)
  {
    if (Guid.TryParse(chat.Id, out var chatId))
    {
      await ChatService.PinChatAsync(chatId, !chat.IsPinned);
      ChatCacheService.InvalidateCache(chatId);
      await LoadSidebarChatsAsync();
      if (_chatId == chat.Id) _chatIsPinned = !chat.IsPinned;
      StateHasChanged();
    }
  }

  private async Task DeleteChat(ChatDrawer.SidebarChat chat)
  {
    if (Guid.TryParse(chat.Id, out var chatId))
    {
      await ChatService.DeleteChatAsync(chatId);
      ChatCacheService.InvalidateCache(chatId);
      SidebarChats = SidebarChats.Where(c => c.Id != chat.Id).ToList();
      if (_chatId == chat.Id)
      {
        await CreateNewChat();
      }

      StateHasChanged();
    }
  }

  private async Task HandleChatRenamed(ChatDrawer.SidebarChat updatedChat)
  {
    var fullChat = await ChatService.GetChatAsync(Guid.Parse(updatedChat.Id));
    var updateReq = new ChatService.UpdateChatRequest(
      updatedChat.Name,
      updatedChat.Model,
      fullChat.Messages,
      updatedChat.IsPinned
    );
    await ChatService.UpdateChatAsync(Guid.Parse(updatedChat.Id), updateReq);
    await LoadSidebarChatsAsync();
    if (_chatId == updatedChat.Id) _chatName = updatedChat.Name;
    StateHasChanged();
  }

  private async Task HandleRegenerateMessage(ClientChatMessage? messageToRegen)
  {
    if (_isSendingMessage) return;
    if (messageToRegen == null) return;
    _isSendingMessage = true;
    SetWaitingForFirstChunk(false);
    StateHasChanged();
    await SignalRService.EnsureConnectionAsync();

    var idx = _chatHistory.IndexOf(messageToRegen);
    if (idx == -1)
    {
      _isSendingMessage = false;
      StateHasChanged();
      return;
    }

    List<ServiceChatMessage> messagesToSendForAi;
    ClientChatMessage? targetAiMessage;

    if (messageToRegen.IsUser)
    {
      _chatHistory.RemoveAll(m => _chatHistory.IndexOf(m) > idx && !m.IsUser);
      if (idx + 1 < _chatHistory.Count && !_chatHistory[idx + 1].IsUser)
      {
        _chatHistory.RemoveAt(idx + 1);
      }

      messagesToSendForAi = _chatHistory.Take(idx + 1)
        .Select(x => new ServiceChatMessage
        {
          Role = x.IsUser ? "user" : "assistant",
          Content = x.Text,
          FileIds = x.FileIds
        })
        .ToList();

      targetAiMessage = new ClientChatMessage { IsUser = false, Text = "", IsStreaming = true };
      if (idx + 1 < _chatHistory.Count) _chatHistory.Insert(idx + 1, targetAiMessage);
      else _chatHistory.Add(targetAiMessage);
    }
    else
    {
      _chatHistory[idx] = new ClientChatMessage { IsUser = false, Text = "", IsStreaming = true };
      targetAiMessage = _chatHistory[idx];

      messagesToSendForAi = _chatHistory.Take(idx)
        .Select(x => new ServiceChatMessage
        {
          Role = x.IsUser ? "user" : "assistant",
          Content = x.Text,
          FileIds = x.FileIds
        })
        .ToList();
    }

    TouchTranscript();
    StateHasChanged();

    await StreamAiMessage(messagesToSendForAi, targetAiMessage, SaveChatAfterStreaming, err => targetAiMessage.Text = $"[Error regenerating: {err}]");
  }

  private async Task HandleEditMessage(ClientChatMessage? m)
  {
    if (m == null || _chatInputAreaRef == null) return;

    _messageBeingEdited = m;

    // Set the files in Chat.razor's state, which will flow down via @bind-CurrentMessageFiles
    CurrentMessageFiles = m.FileIds
      .Select(fid => new FileUploadService.UploadedFileInfo { Id = fid, OriginalFileName = $"File_{fid.ToString()[..4]}..." })
      .ToList();

    // Set the show file upload state, which will flow down via @bind-ShowFileUpload
    _showFileUpload = CurrentMessageFiles.Any();

    // Directly call the public method on ChatInputArea to set its internal text field content
    await _chatInputAreaRef.SetInputText(m.Text, "HandleEditMessage");

    Snackbar.Add("Message content and associated files (if any) restored for editing.", Severity.Info);
    // StateHasChanged() is implicitly called by setting CurrentMessageFiles and _showFileUpload
    // due to their binding, but explicitly calling it here ensures everything is in sync
    // if other properties of Chat.razor's UI need immediate refresh.
    StateHasChanged(); 
  }

  private async Task HandleCopyMessage(ClientChatMessage? m)
  {
    if (m == null) return;
    try
    {
      await Js.InvokeVoidAsync("navigator.clipboard.writeText", m.Text);
      Snackbar.Add("Message copied to clipboard", Severity.Success);
    }
    catch (Exception ex)
    {
      Snackbar.Add($"Failed to copy: {ex.Message}", Severity.Error);
    }
  }

  private async Task HandleBranchMessage(ClientChatMessage? messageToBranchFrom)
  {
    if (messageToBranchFrom == null) return;
    var idx = _chatHistory.IndexOf(messageToBranchFrom);
    if (idx == -1) return;

    var branchChatHistory = _chatHistory.Take(idx + 1).ToList();

    var branchName = $"Branch: {_chatName}".Truncate(50);
    var createReq = new ChatService.CreateChatRequest(
      branchName,
      ChatSelectedModel,
      branchChatHistory.Select(m => new ChatService.ChatMessageDto(
        m.IsUser ? "user" : "assistant",
        m.Text,
        m.FileIds)
      ).ToArray(),
      false
    );
    var newId = await ChatService.CreateChatAsync(createReq);

    await LoadSidebarChatsAsync();

    var newSidebarChat = SidebarChats.FirstOrDefault(c => c.Id == newId.ToString());
    if (newSidebarChat != null)
    {
      await LoadChat(newSidebarChat);
      Snackbar.Add("Chat branched successfully", Severity.Success);
    }
    else
    {
      _chatId = newId.ToString();
      _chatName = branchName;
      _chatHistory = branchChatHistory;
      TouchTranscript();
      _chatIsPinned = false;
      CurrentMessageFiles.Clear();
      _showFileUpload = false;
      // Call SetInputText to clear the ChatInputArea's internal text
      if (_chatInputAreaRef != null)
      {
          await _chatInputAreaRef.SetInputText("", "HandleBranchMessage");
      }
      NavigationManager.NavigateTo($"/Chat?chatId={_chatId}", forceLoad: false);
      Snackbar.Add("Chat branched, but could not auto-load. Please select from sidebar.", Severity.Warning);
      StateHasChanged();
    }
  }
}
