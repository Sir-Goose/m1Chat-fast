@page "/Profile"
@inject UserService UserService
@inject IJSRuntime Js
@inject NavigationManager NavigationManager
@inject ISnackbar Snackbar
@inject ModelPreferencesService ModelPreferences
@using m1Chat.Client.Services
@using System.Text.Json

<MudContainer MaxWidth="MaxWidth.Medium">
    <MudPaper Elevation="3" Class="pa-4 rounded-lg blur-background">
        <MudGrid Spacing="0">
            <!-- Header -->
            <MudItem xs="12" Class="d-flex align-center">
                <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" Color="Color.Inherit" OnClick="NavigateToChat"
                    Edge="Edge.Start" />
                <MudText Typo="Typo.h4" Class="flex-grow-1 text-center pr-10">
                    User Profile
                </MudText>
            </MudItem>

            <!-- Account Info -->
            <MudItem xs="12" Class="mb-4 ml-2">
                <MudCard Elevation="0">
                    <MudCardContent>
                        <MudText Typo="Typo.h5" Class="mb-2">
                            Account Information
                        </MudText>
                        <MudText Typo="Typo.h6" Color="Color.Primary">
                            Email
                        </MudText>
                        <MudText>
                            @UserEmail
                        </MudText>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Usage Stats -->
            <MudItem xs="12" Class="mb-4 ml-2">
                <MudCard Elevation="0">
                    <MudCardContent>
                        <MudText Typo="Typo.h5" Class="mb-2">Usage Statistics</MudText>
                        <MudGrid Class="rounded-xl">
                            <MudItem xs="12" sm="4" Class="text-center">
                                <MudText Typo="Typo.h4" Color="Color.Primary">
                                    @TotalChats</MudText>
                                <MudText>Chat Threads</MudText>
                            </MudItem>
                            <MudItem xs="12" sm="4" Class="text-center">
                                <MudText Typo="Typo.h4" Color="Color.Primary">
                                    @TotalMessages</MudText>
                                <MudText>Messages Sent</MudText>
                            </MudItem>
                        </MudGrid>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Model Selection -->
            <MudPaper Elevation="0" Class="ml-4">
                <MudText Typo="Typo.h5" Class="mb-2">Enable/Disable Models</MudText>
                <MudDataGrid Items="@models" Filterable="false" SortMode="@SortMode.None" Groupable="true"
                    GroupExpanded="false" MultiSelection="true" SelectedItems="@selectedModels"
                    SelectedItemsChanged="@(EventCallback.Factory.Create<HashSet<Model>>(this, OnSelectedItemsChanged))">
                    <Columns>
                        <SelectColumn T="Model" />
                        <PropertyColumn Property="x => x.Name" Title="Model" />
                        <PropertyColumn Property="x => x.Provider" Grouping>
                            <GroupTemplate>
                                <div style="display: flex; align-items: center; gap: 8px;">
                                    <MudIcon Icon="@GetProviderIcon(context.Grouping.Key?.ToString())" Size="Size.Small" />
                                    <span>@context.Grouping.Key (@context.Grouping.Count() models)</span>
                                </div>
                            </GroupTemplate>
                        </PropertyColumn>
                    </Columns>
                </MudDataGrid>

                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-3 rounded-xl"
                    OnClick="SaveModelPreferences" Disabled="@isSaving">
                    @(isSaving ? "Saving..." : "Save Model Preferences")
                </MudButton>
            </MudPaper>

            
            <!-- Default Model -->
            <MudItem xs="12" Class="ml-4 mr-4 mt-8">
                <MudPaper Elevation="0">
                    <MudText Typo="Typo.h5" Class="mb-2">Set Default Model</MudText>
                    <MudSelect
                    @bind-Value = "defaultModel"
                    Variant = "Variant.Outlined"
                    >
                    @foreach (var model in models) 
                    {
                        <MudSelectItem Value="@model.Name">@model.Name</MudSelectItem> 
                    }
                    </MudSelect>
                    <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true" Class="mt-3 rounded-xl"
                            OnClick="SaveDefaultModel" Disabled="@isSaving">
                            @(isSaving ? "Saving..." : "Save Default Model")
                    </MudButton>
                </MudPaper>
            </MudItem>



            <!-- API Keys -->
            <MudItem xs="12" Class="mb-4 mt-2">
                <MudCard Elevation="0">
                    <MudCardContent>
                        <MudText Typo="Typo.h5" Class="mb-2">Bring Your Own Key</MudText>
                        <MudText Class="mt-2">OpenRouter</MudText>
                        <MudTextField @bind-Value="Openrouterkey" Label="sk-1234...." Variant="Variant.Outlined"
                            Class="rounded-xl" Disabled="@isSaving" InputType="@PasswordInput"
                            AdornmentIcon="@PasswordInputIcon" Adornment="Adornment.End"
                            OnAdornmentClick="TogglePasswordVisibility"></MudTextField>
                        <MudText Class="mt-4">AI Studio</MudText>
                        <MudTextField @bind-Value="AiStudioKey" Label="sk-1234...." Variant="Variant.Outlined"
                            Class="rounded-xl" Disabled="@isSaving" InputType="@PasswordInput"
                            AdornmentIcon="@PasswordInputIcon" Adornment="Adornment.End"
                            OnAdornmentClick="TogglePasswordVisibility"></MudTextField>
                        <MudText Class="mt-4">Chutes</MudText>
                        <MudTextField @bind-Value="ChutesKey" Label="sk-1234...." Variant="Variant.Outlined"
                            Class="rounded-xl" Disabled="@isSaving" InputType="@PasswordInput"
                            AdornmentIcon="@PasswordInputIcon" Adornment="Adornment.End"
                            OnAdornmentClick="TogglePasswordVisibility"></MudTextField>
                        <MudText Class="mt-4">Mistral</MudText>
                        <MudTextField @bind-Value="MistralKey" Label="sk-1234...." Variant="Variant.Outlined"
                            Class="rounded-xl" Disabled="@isSaving" InputType="@PasswordInput"
                            AdornmentIcon="@PasswordInputIcon" Adornment="Adornment.End"
                            OnAdornmentClick="TogglePasswordVisibility"></MudTextField>
                        <MudText Class="mt-4">Groq</MudText>
                        <MudTextField @bind-Value="GroqKey" Label="sk-1234...." Variant="Variant.Outlined"
                            Class="rounded-xl" Disabled="@isSaving" InputType="@PasswordInput"
                            AdornmentIcon="@PasswordInputIcon" Adornment="Adornment.End"
                            OnAdornmentClick="TogglePasswordVisibility"></MudTextField>
                        <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                            Class="mt-3 rounded-xl" OnClick="SaveApiKeys" Disabled="@isSaving">
                            @(isSaving ? "Saving..." : "Save API Keys")
                        </MudButton>
                    </MudCardContent>
                </MudCard>
            </MudItem>

            <!-- Logout -->
            <MudItem xs="12" Class="text-center mt-4">
                <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.Logout"
                    OnClick="Logout" Class="mt-4">
                    Logout
                </MudButton>
            </MudItem>
        </MudGrid>
    </MudPaper>
</MudContainer>

@code {
    private bool isShow = false;
    private string PasswordInputIcon = Icons.Material.Filled.VisibilityOff;
    private InputType PasswordInput = InputType.Password;
    void TogglePasswordVisibility()
    {
        if (isShow)
        {
            isShow = false;
            PasswordInputIcon = Icons.Material.Filled.VisibilityOff;
            PasswordInput = InputType.Password;
        }
        else
        {
            isShow = true;
            PasswordInputIcon = Icons.Material.Filled.Visibility;
            PasswordInput = InputType.Text;
        }
    }
    private string UserEmail { get; set; } = "Loading...";
    private int TotalChats = 0;
    private int TotalMessages = 0;
    private bool isSaving = false; // Controls UI state for both saves

    private string Openrouterkey = "";
    private string AiStudioKey = "";
    private string ChutesKey = "";
    private string MistralKey = "";
    private string GroqKey = "";

    public record Model(string Name, string Provider);

    public List<Model> models = new();
    public HashSet<Model> selectedModels = new HashSet<Model>();
    private string defaultModel = "";

    protected override async Task OnInitializedAsync()
    {
        try
        {
            if (OperatingSystem.IsBrowser())
            {
                await Js.InvokeVoidAsync("window.hideBlazorLoadingScreen");
            }
            UserEmail = await UserService.GetUserEmailAsync() ?? "Unknown";

            var stats = await UserService.GetUserStatsAsync();
            if (stats != null)
            {
                TotalChats = stats.TotalChats;
                TotalMessages = stats.TotalMessages;
            }

            var keys = await UserService.GetUserApiKeysAsync();
            Openrouterkey = keys.GetValueOrDefault("OpenRouter") ?? "";
            AiStudioKey = keys.GetValueOrDefault("AIStudio") ?? "";
            ChutesKey = keys.GetValueOrDefault("Chutes") ?? "";
            MistralKey = keys.GetValueOrDefault("Mistral") ?? "";
            GroqKey = keys.GetValueOrDefault("Groq") ?? "";

            // Initialize ModelPreferences service and load enabled models
            await ModelPreferences.InitializeAsync();

            // Populate the 'models' list from the ModelPreferencesService
            var allAvailableModels = ModelPreferences.GetAllAvailableModels();
            var modelProviders = ModelPreferences.GetModelProviders();
            defaultModel = ModelPreferences.DefaultModel;

            models = allAvailableModels
            .Select(modelName => new Model(modelName, modelProviders.GetValueOrDefault(modelName, "Unknown")))
            .OrderBy(m => m.Provider == "Free Tier" ? "0" : m.Provider)
            .ThenBy(m => m.Name)
            .ToList();

            // Select models that are currently enabled based on preferences
            selectedModels = new HashSet<Model>(
            models.Where(m => ModelPreferences.EnabledModels.Contains(m.Name))
            );
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error loading profile: {ex.Message}", Severity.Error);
        }
    }

    private void OnSelectedItemsChanged(HashSet<Model> items) => selectedModels = items;

    private void Logout()
    {
        // Redirect to the server-side logout endpoint
        NavigationManager.NavigateTo("/auth/logout", forceLoad: true);
    }

    private void NavigateToChat() => NavigationManager.NavigateTo("/Chat");

    private async Task SaveApiKeys()
    {
        isSaving = true;
        try
        {
            var keys = new Dictionary<string, string>
            {
                ["OpenRouter"] = Openrouterkey ?? "",
                ["AIStudio"] = AiStudioKey ?? "",
                ["Chutes"] = ChutesKey ?? "",
                ["Mistral"] = MistralKey ?? "",
                ["Groq"] = GroqKey ?? ""
            };

            await UserService.SaveUserApiKeysAsync(keys);
            Snackbar.Add("API keys saved successfully!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save API keys: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SaveModelPreferences()
    {
        isSaving = true;
        try
        {
            var enabledModelNames = selectedModels.Select(m => m.Name).ToList();
            await ModelPreferences.SetEnabledModels(enabledModelNames);
            Snackbar.Add("Model preferences saved!", Severity.Success);
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save model preferences: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }

    private async Task SaveDefaultModel()
    {
        isSaving = true;
        try
        {
            if (defaultModel != null) {
                await ModelPreferences.SetDefaultModel(defaultModel);
                Snackbar.Add("Default model saved!", Severity.Success);
            }
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Failed to save default model: {ex.Message}", Severity.Error);
        }
        finally
        {
            isSaving = false;
        }
    }

    private string GetProviderIcon(string? provider) => provider switch
    {
        "Free Tier" => Icons.Material.Filled.MoneyOff,
        "AI Studio" => Icons.Material.Filled.AutoAwesome,
        "Chutes" => Icons.Material.Filled.Rocket,
        "Mistral AI" => Icons.Material.Filled.Psychology,
        "Openrouter" => Icons.Material.Filled.Router,
        "Groq" => Icons.Material.Filled.Speed,
        _ => Icons.Material.Filled.Category
    };

}
