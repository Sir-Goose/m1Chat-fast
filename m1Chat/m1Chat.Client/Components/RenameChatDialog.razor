<MudDialog>
    <DialogContent>
        <MudText Typo="Typo.h6"></MudText>
        <MudTextField @ref="_newNameTextField" @bind-Value="NewName" Label="Chat Name" Variant="Variant.Outlined" @onkeyup="HandleKeyUp"/>
    </DialogContent>
    <DialogActions>
        <MudButton OnClick="Submit" Color="Color.Primary" Variant="Variant.Filled">OK</MudButton>
        <MudButton OnClick="Cancel" Color="Color.Secondary" Variant="Variant.Text">Cancel</MudButton>
    </DialogActions>
</MudDialog>
